NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side pepper for HMAC-SHA256 hashing of callcenter API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Once set, all new API keys will use peppered hashes.
# Existing plain SHA-256 keys continue to work (fallback in callcenter-auth.ts).
API_KEY_PEPPER=

# Gemini AI pro personalizaci emailů a rozhodování v sekvencích
# Získejte na: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Brevo webhook secret pro ověření email tracking eventů
# Nastavte v Brevo dashboard → Settings → Webhooks
BREVO_WEBHOOK_SECRET=
