# API Base URL - choose based on environment
# For local development:
# API_BASE_URL=http://localhost:3000/api
# For production (Vercel):
API_BASE_URL=https://vitalspace-crm.vercel.app/api

# MCP API key — required. Without it, all CRM endpoints reject requests
# with "Přístup odepřen". Generate one with `generateMcpApiKey()` in
# lib/supabase/mcp-auth.ts and insert it into the `mcp_api_keys` table
# (migration 064) with permissions ['crm:read', 'crm:write'].
VITALSPACE_API_KEY=vs_mcp_replace_me_with_real_key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
